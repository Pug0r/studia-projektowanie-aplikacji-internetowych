@page "/admin"
@using ScentMarket.Shared
@using ScentMarket.Client.Http
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject ApiClient ApiClient

<PageTitle>Admin Dashboard | ScentMarket</PageTitle>

<div class="admin-container fade-in">
    <div class="admin-header">
        <h1>Admin Dashboard</h1>
        <p class="subtitle">Manage platform users.</p>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-error">@_error</div>
    }

    @if (!string.IsNullOrEmpty(_success))
    {
        <div class="alert alert-success">@_success</div>
    }

    <!-- System Utilities -->
    <div class="admin-section mb-4">
        <h2>System Utilities</h2>
        <div class="form-actions">
            <button class="btn-primary" @onclick="HandleReloadCache" disabled="@_isReloadingCache">
                @if (_isReloadingCache) { <span class="spinner-small"></span> } else { <span>Reload Perfume Cache</span> }
            </button>
        </div>
        <p class="subtitle mt-2" style="margin-top: 1rem;">Force the backend to re-query all perfumes from the database and update the in-memory cache.</p>
    </div>

    <!-- Add New User Form -->
    <div class="admin-section">
        <h2>Add New User</h2>
        <EditForm Model="_newUser" OnValidSubmit="HandleAddUser" class="form-grid">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="_newUser.Username" class="form-control" />
                <ValidationMessage For="@(() => _newUser.Username)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="_newUser.Email" class="form-control" type="email" />
                <ValidationMessage For="@(() => _newUser.Email)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="_newUser.Password" class="form-control" type="password" />
                <ValidationMessage For="@(() => _newUser.Password)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Role</label>
                <InputSelect @bind-Value="_newUser.Role" class="form-control">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </InputSelect>
                <ValidationMessage For="@(() => _newUser.Role)" class="validation-message" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting) { <span class="spinner-small"></span> } else { <span>Add User</span> }
                </button>
            </div>
        </EditForm>
    </div>

    <!-- Add New Perfume Form -->
    <div class="admin-section mt-4">
        <h2>Add New Perfume</h2>
        
        @if (!string.IsNullOrEmpty(_perfumeError))
        {
            <div class="alert alert-error">@_perfumeError</div>
        }

        @if (!string.IsNullOrEmpty(_perfumeSuccess))
        {
            <div class="alert alert-success">@_perfumeSuccess</div>
        }

        <EditForm Model="_newPerfume" OnValidSubmit="HandleAddPerfume" class="form-grid">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label>Brand</label>
                <InputText @bind-Value="_newPerfume.Brand" class="form-control" />
                <ValidationMessage For="@(() => _newPerfume.Brand)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Name</label>
                <InputText @bind-Value="_newPerfume.Name" class="form-control" />
                <ValidationMessage For="@(() => _newPerfume.Name)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Concentration</label>
                <InputSelect @bind-Value="_newPerfume.Concentration" class="form-control">
                    <option value="EDT">EDT (Eau de Toilette)</option>
                    <option value="EDP">EDP (Eau de Parfum)</option>
                    <option value="Parfum">Parfum</option>
                    <option value="Extrait">Extrait de Parfum</option>
                    <option value="EDC">EDC (Eau de Cologne)</option>
                </InputSelect>
                <ValidationMessage For="@(() => _newPerfume.Concentration)" class="validation-message" />
            </div>

            <div class="form-group">
                <label>Image</label>
                <InputFile OnChange="HandleImageSelection" class="form-control" style="padding-top: 0.5rem;" accept="image/*" />
                <ValidationMessage For="@(() => _newPerfume.Image)" class="validation-message" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary" disabled="@_isSubmittingPerfume">
                    @if (_isSubmittingPerfume) { <span class="spinner-small"></span> } else { <span>Add Perfume</span> }
                </button>
            </div>
        </EditForm>
    </div>

    <!-- Users Table -->
    <div class="admin-section mt-4">
        <h2>Registered Users</h2>
        @if (_users == null)
        {
            <div class="loading-state">Loading users...</div>
        }
        else if (!_users.Any())
        {
            <div class="empty-state">No users found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Joined</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr>
                                <td>@user.Username</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="role-badge @(user.Role.ToLower())">@user.Role</span>
                                </td>
                                <td>@user.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                                <td>
                                    <button class="btn-danger btn-sm" @onclick="() => HandleDeleteUser(user.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<style>
    .admin-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
    }

    .admin-header {
        margin-bottom: 2rem;
        text-align: center;
    }

    .admin-header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold-light);
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .admin-section {
        background: var(--bg-surface);
        border: 1px solid #2e2e2e;
        border-radius: 8px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .admin-section h2 {
        font-size: 1.25rem;
        color: var(--text-primary);
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #333;
        padding-bottom: 0.5rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        align-items: end;
    }

    .form-actions {
        display: flex;
        align-items: center;
        padding-bottom: 2px;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

    .admin-table th, .admin-table td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid #2e2e2e;
    }

    .admin-table th {
        font-weight: 600;
        color: var(--gold);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
    }

    .admin-table td {
        color: var(--text-secondary);
        font-size: 0.95rem;
    }

    .role-badge {
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .role-badge.admin {
        background: rgba(180, 140, 60, 0.2);
        color: var(--gold-light);
        border: 1px solid var(--gold);
    }

    .role-badge.user {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-muted);
        border: 1px solid #444;
    }

    .btn-sm {
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
    }

    .btn-danger {
        background: rgba(220, 53, 69, 0.1);
        color: #ff6b6b;
        border: 1px solid #ff6b6b;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-danger:hover {
        background: #ff6b6b;
        color: #fff;
    }

    .mt-4 {
        margin-top: 2rem;
    }
</style>

@code {
    private List<AdminUserDto>? _users;
    private AdminCreateUserRequest _newUser = new();
    private string? _error;
    private string? _success;
    private bool _isSubmitting = false;

    private class NewPerfumeModel
    {
        [System.ComponentModel.DataAnnotations.Required] 
        public string Brand { get; set; } = string.Empty;
        
        [System.ComponentModel.DataAnnotations.Required] 
        public string Name { get; set; } = string.Empty;
        
        [System.ComponentModel.DataAnnotations.Required] 
        public string Concentration { get; set; } = "EDP";
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select an image.")] 
        public Microsoft.AspNetCore.Components.Forms.IBrowserFile? Image { get; set; }
    }

    private NewPerfumeModel _newPerfume = new();
    private string? _perfumeError;
    private string? _perfumeSuccess;
    private bool _isSubmittingPerfume;
    private bool _isReloadingCache;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _users = await ApiClient.GetUsersAsync();
    }

    private async Task HandleAddUser()
    {
        _isSubmitting = true;
        _error = null;
        _success = null;

        var (success, error) = await ApiClient.CreateUserAsync(_newUser);
        if (success)
        {
            _success = $"User {_newUser.Username} successfully created!";
            _newUser = new AdminCreateUserRequest(); // Reset form
            await LoadUsersAsync(); // Refresh list
        }
        else
        {
            _error = error ?? "Failed to create user.";
        }

        _isSubmitting = false;
    }

    private async Task HandleDeleteUser(Guid id)
    {
        _error = null;
        _success = null;

        var (success, error) = await ApiClient.DeleteUserAsync(id);
        if (success)
        {
            _success = "User successfully deleted.";
            await LoadUsersAsync();
        }
        else
        {
            _error = error ?? "Failed to delete user.";
        }
    }

    private void HandleImageSelection(InputFileChangeEventArgs e)
    {
        _newPerfume.Image = e.File;
    }

    private async Task HandleAddPerfume()
    {
        _isSubmittingPerfume = true;
        _perfumeError = null;
        _perfumeSuccess = null;

        var (success, error) = await ApiClient.CreatePerfumeAsync(
            _newPerfume.Brand, 
            _newPerfume.Name, 
            _newPerfume.Concentration, 
            _newPerfume.Image!);
        
        if (success)
        {
            _perfumeSuccess = $"Perfume '{_newPerfume.Brand} - {_newPerfume.Name}' successfully added!";
            _newPerfume = new NewPerfumeModel();
        }
        else
        {
            _perfumeError = error ?? "Failed to add perfume.";
        }

        _isSubmittingPerfume = false;
    }

    private async Task HandleReloadCache()
    {
        _isReloadingCache = true;
        _perfumeError = null;
        _perfumeSuccess = null;
        _error = null;
        _success = null;

        var (success, error, count) = await ApiClient.ReloadPerfumeCacheAsync();
        if (success)
        {
            _success = $"Successfully reloaded {count} perfumes into the cache.";
        }
        else
        {
            _error = error ?? "Failed to reload cache.";
        }
        
        _isReloadingCache = false;
    }
}
