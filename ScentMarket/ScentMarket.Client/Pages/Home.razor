@page "/"
@attribute [Authorize]
@inject ApiClient ApiClient
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>ScentMarket — Browse</PageTitle>

<div class="home-header">
    <div class="home-header-top">
        <div>
            <h1 class="home-title">Discover Decants</h1>
            <p class="home-subtitle">
                @if (string.IsNullOrWhiteSpace(_search))
                {
                    <span>@_totalCount perfume@(_totalCount == 1 ? "" : "s") available</span>
                }
                else
                {
                    <span>@_totalCount result@(_totalCount == 1 ? "" : "s") for &ldquo;@_search&rdquo;</span>
                }
            </p>
        </div>
    </div>

    <div class="search-bar-wrapper">
        <span class="search-icon">🔍</span>
        <input
            class="search-input"
            type="search"
            placeholder="Search by name or brand…"
            value="@_search"
            @oninput="OnSearchInput" />
        @if (!string.IsNullOrWhiteSpace(_search))
        {
            <button class="search-clear-btn" @onclick="ClearSearch" title="Clear">✕</button>
        }
    </div>
</div>

@if (_perfumes.Count == 0 && _loading)
{
    <div class="grid-loading">
        <div class="spinner"></div>
        <p>Loading perfumes…</p>
    </div>
}
else if (_perfumes.Count == 0)
{
    <div class="grid-empty">
        <span>No perfumes found.</span>
    </div>
}
else
{
    <div class="perfume-grid">
        @foreach (var perfume in _perfumes)
        {
            <div class="perfume-card">
                <div class="perfume-card-image">
                    @if (perfume.ImageUrl is not null)
                    {
                        <img src="@perfume.ImageUrl" alt="@perfume.Brand @perfume.Name" class="perfume-img" />
                    }
                    else
                    {
                        <span class="perfume-placeholder-icon">🧴</span>
                    }
                </div>
                <div class="perfume-card-body">
                    <div class="perfume-brand">@perfume.Brand</div>
                    <div class="perfume-name">@perfume.Name</div>
                    <div class="perfume-meta">@perfume.Concentration</div>
                    <div class="perfume-price">Price TBD</div>
                </div>
            </div>
        }
    </div>
}

@if (_hasMore)
{
    <div id="scroll-sentinel" class="scroll-sentinel">
        @if (_loading) { <div class="spinner spinner-sm"></div> }
    </div>
}
else if (_perfumes.Count > 0)
{
    <div class="scroll-end">✦ All perfumes loaded ✦</div>
}

@code {
    private readonly List<Perfume> _perfumes = [];
    private int _page = 1;
    private const int PageSize = 12;
    private bool _hasMore = true;
    private bool _loading = false;
    private int _totalCount = 0;
    private bool _observerSetup = false;
    private DotNetObjectReference<Home>? _dotNetRef;

    private string _search = string.Empty;
    private System.Threading.CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadNextPageAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hasMore && !_observerSetup)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _observerSetup = await JS.InvokeAsync<bool>(
                "infiniteScroll.observe", "scroll-sentinel", _dotNetRef, nameof(LoadNextPageAsync));
        }
        else if (!_hasMore && _observerSetup)
        {
            await JS.InvokeVoidAsync("infiniteScroll.unobserve", "scroll-sentinel");
            _observerSetup = false;
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;

        // Cancel any pending debounce timer
        _debounceCts?.Cancel();
        _debounceCts = new System.Threading.CancellationTokenSource();
        var token = _debounceCts.Token;

        _ = Task.Delay(350, token).ContinueWith(async t =>
        {
            if (t.IsCanceled) return;
            await InvokeAsync(ResetAndSearchAsync);
        }, TaskScheduler.Default);
    }

    private async Task ClearSearch()
    {
        _search = string.Empty;
        await ResetAndSearchAsync();
    }

    private async Task ResetAndSearchAsync()
    {
        // Tear down observer before resetting the list (sentinel will be removed from DOM)
        if (_observerSetup)
        {
            await JS.InvokeVoidAsync("infiniteScroll.unobserve", "scroll-sentinel");
            _observerSetup = false;
        }

        _perfumes.Clear();
        _page = 1;
        _hasMore = true;
        _totalCount = 0;

        await LoadNextPageAsync();
    }

    [JSInvokable]
    public async Task LoadNextPageAsync()
    {
        if (_loading || !_hasMore) return;

        _loading = true;
        StateHasChanged();

        var result = await ApiClient.GetPerfumesAsync(_page, PageSize, _search);
        if (result is not null)
        {
            _perfumes.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _hasMore = result.HasMore;
            _page++;
        }
        else
        {
            _hasMore = false;
        }

        _loading = false;
        _observerSetup = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        if (_observerSetup)
            await JS.InvokeVoidAsync("infiniteScroll.unobserve", "scroll-sentinel");
        _dotNetRef?.Dispose();
    }
}