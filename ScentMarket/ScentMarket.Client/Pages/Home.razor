@page "/"
@attribute [Authorize]
@inject ApiClient ApiClient
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>ScentMarket — Browse</PageTitle>

<div class="home-header">
    <h1 class="home-title">Discover Decants</h1>
    <p class="home-subtitle">@_totalCount perfume@(_totalCount == 1 ? "" : "s") available</p>
</div>

@if (_perfumes.Count == 0 && _loading)
{
    <div class="grid-loading">
        <div class="spinner"></div>
        <p>Loading perfumes…</p>
    </div>
}
else if (_perfumes.Count == 0)
{
    <div class="grid-empty">No perfumes found.</div>
}
else
{
    <div class="perfume-grid">
        @foreach (var perfume in _perfumes)
        {
            <div class="perfume-card">
                <div class="perfume-card-image">
                    <span class="perfume-placeholder-icon">🧴</span>
                </div>
                <div class="perfume-card-body">
                    <div class="perfume-brand">@perfume.Brand</div>
                    <div class="perfume-name">@perfume.Name</div>
                    <div class="perfume-meta">@perfume.Concentration</div>
                    <div class="perfume-price">Price TBD</div>
                </div>
            </div>
        }
    </div>
}

@if (_hasMore)
{
    <div id="scroll-sentinel" class="scroll-sentinel">
        @if (_loading) { <div class="spinner spinner-sm"></div> }
    </div>
}
else if (_perfumes.Count > 0)
{
    <div class="scroll-end">✦ All perfumes loaded ✦</div>
}

@code {
    private readonly List<Perfume> _perfumes = [];
    private int _page = 1;
    private const int PageSize = 12;
    private bool _hasMore = true;
    private bool _loading = false;
    private int _totalCount = 0;
    private bool _observerSetup = false;
    private DotNetObjectReference<Home>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        await LoadNextPageAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Try to set up observer whenever sentinel is in DOM but not yet observed.
        if (_hasMore && !_observerSetup)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            _observerSetup = await JS.InvokeAsync<bool>(
                "infiniteScroll.observe", "scroll-sentinel", _dotNetRef, nameof(LoadNextPageAsync));
        }
        else if (!_hasMore && _observerSetup)
        {
            await JS.InvokeVoidAsync("infiniteScroll.unobserve", "scroll-sentinel");
            _observerSetup = false;
        }
    }

    [JSInvokable]
    public async Task LoadNextPageAsync()
    {
        if (_loading || !_hasMore) return;

        _loading = true;
        StateHasChanged();

        var result = await ApiClient.GetPerfumesAsync(_page, PageSize);
        if (result is not null)
        {
            _perfumes.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _hasMore = result.HasMore;
            _page++;
        }
        else
        {
            _hasMore = false;
        }

        _loading = false;
        _observerSetup = false; // force re-observe after re-render (sentinel may have moved)
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_observerSetup)
            await JS.InvokeVoidAsync("infiniteScroll.unobserve", "scroll-sentinel");
        _dotNetRef?.Dispose();
    }
}