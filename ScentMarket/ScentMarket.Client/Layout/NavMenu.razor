@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Nav

<nav class="nav-bar">
    <a class="nav-brand" href="/">🧴 ScentMarket</a>

    <div class="nav-links">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Browse</NavLink>
        <NavLink class="nav-link" href="my-offers">My Offers</NavLink>
        <NavLink class="nav-link" href="transactions">Transactions</NavLink>
        <NavLink class="nav-link" href="account">Account</NavLink>
        <AuthorizeView Roles="Admin">
            <Authorized Context="adminCtx">
                <NavLink class="nav-link" href="admin" style="color: var(--gold) !important; border-color: rgba(180, 140, 60, 0.3);">Admin</NavLink>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="nav-user">
        <AuthorizeView>
            <Authorized>
                <span class="nav-username">@context.User.FindFirst("unique_name")?.Value</span>
                <button class="nav-signout-btn" @onclick="LogoutAsync">Sign out</button>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private async Task LogoutAsync()
    {
        await AuthStateProvider.NotifyUserLoggedOutAsync();
        Nav.NavigateTo("/login");
    }
}
